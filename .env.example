CODEXA_LLM_PROVIDER=openai
CODEXA_LLM_MODEL=gpt-4o-mini
CODEXA_LLM_TEMPERATURE=0.0

# Put real keys in .env (do not commit)
OPENAI_API_KEY=
GROQ_API_KEY=

# Frontend origins allowed to call the backend (comma-separated)
CODEXA_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Optional storage dirs (Render: use /var/data)
CODEXA_INDEX_DIR=.codexa/indexes
CODEXA_STATE_DIR=.codexa/state
